# Flask
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
DATABASE_URL=mysql+pymysql://user:pass@localhost/oddsiq
REDIS_URL=redis://localhost:6379/0
FRONTEND_URL=http://localhost:5173

# Sports APIs
API_FOOTBALL_KEY=your-api-football-key
THE_ODDS_API_KEY=your-the-odds-api-key
API_TENNIS_KEY=your-api-tennis-key

# Affiliate URLs (append affiliate code as query param)
BETWAY_AFFILIATE_URL=https://betway.com.gh/?ref=
ONEXBET_AFFILIATE_URL=https://1xbet.com/?ref=
SPORTYBET_AFFILIATE_URL=https://sportybet.com/?ref=
BET365_AFFILIATE_URL=https://bet365.com/?ref=
AFFILIATE_CODE=oddsiq

# Paystack
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@oddsiq.com

# Subscription Pricing (in GHS pesewas)
MONTHLY_PLAN_AMOUNT=5000
ANNUAL_PLAN_AMOUNT=50000
